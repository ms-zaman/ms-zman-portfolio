---
import BlogLayout from '../layouts/BlogLayout.astro';
import Button from '../components/sky/Button.astro';
---

<BlogLayout
  title="404 — Page Not Found"
  description="The page you're looking for doesn't exist or has been moved."
  canonicalPath="/404"
>
  <div class="[ notfound ] [ wrapper ]">
    <p class="nf-code">404</p>
    <h1 class="nf-title">Page not found</h1>
    <p class="nf-text">The page you&apos;re looking for doesn&apos;t exist or has been moved.</p>
    <Button href="/" variant="solid">Back to Home <span aria-hidden="true">→</span></Button>
  </div>
</BlogLayout>
