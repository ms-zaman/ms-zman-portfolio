---
import type { ImageMetadata } from 'astro';
import defaultFeaturedImage from '../images/ms-zaman-featured-img.webp';

interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  canonicalPath?: string;
  ogImage?: string | ImageMetadata;
}

const {
  title = 'MS Zaman — Frontend Developer | React & WordPress Specialist',
  description = 'MS Zaman — Frontend Developer based in Dhaka, Bangladesh. 5+ years building web interfaces across React, Tailwind CSS, WordPress, and Shopify.',
  ogTitle = 'MS Zaman — Frontend Developer | React & WordPress Specialist',
  ogDescription = '5+ years building web interfaces across React, Tailwind CSS, WordPress, Shopify Liquid, and page builder ecosystems.',
  canonicalPath = '/',
  ogImage = defaultFeaturedImage,
} = Astro.props;

import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const canonicalURL = new URL(canonicalPath, Astro.site);
const ogImageSrc = typeof ogImage === 'string' ? ogImage : ogImage.src;
const ogImageWidth = typeof ogImage === 'string' ? undefined : ogImage.width;
const ogImageHeight = typeof ogImage === 'string' ? undefined : ogImage.height;
const ogImageURL = new URL(ogImageSrc, Astro.site);
const gaId = import.meta.env.PUBLIC_GA_ID || 'G-FL57VDMLD8';
---

<!doctype html>
<html lang="en">
  <head>
    {gaId && (
      <>
        <!-- Google tag (gtag.js) -->
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0b0b0b" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    {ogImageWidth && <meta property="og:image:width" content={ogImageWidth.toString()} />}
    {ogImageHeight && <meta property="og:image:height" content={ogImageHeight.toString()} />}
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="MS Zaman Portfolio" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImageURL} />

    <title>{title}</title>

    <!-- Theme Initialization: Prevents flash of unstyled content (FOUC) -->
    <script is:inline>
      (function() {
        try {
          var savedTheme = localStorage.getItem('theme');
          if (savedTheme === 'light') {
            document.documentElement.setAttribute('data-theme', 'light');
          } else if (savedTheme === 'dark') {
            document.documentElement.removeAttribute('data-theme');
          } else {
            if (window.matchMedia('(prefers-color-scheme: light)').matches) {
              document.documentElement.setAttribute('data-theme', 'light');
            }
          }
        } catch (e) {}
      })();
    </script>

    <!--
      PERFORMANCE: Non-render-blocking font loading strategy.
      1. Preconnect to font origins.
      2. Load fonts with media="print" + onload swap.
      3. <noscript> fallback for non-JS crawlers.
    -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;1,9..40,400&family=DM+Mono:wght@400;500&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;1,9..40,400&family=DM+Mono:wght@400;500&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;1,9..40,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
    </noscript>
  </head>
  <body>
    <div id="scroll-progress" class="scroll-progress-bar" aria-hidden="true"></div>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Navigation />
    <main id="main-content" class="main-content">
      <slot />
    </main>
    <Footer />

    <!-- Interactive micro-effects & Scroll Spy — vanilla JS for speed and zero dependencies -->
    <script is:inline>
      (function() {
        // 1. Intersection Observer for fade-in animations
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.08 });

        document.querySelectorAll('.fade-in').forEach(function(el) {
          observer.observe(el);
        });

        // 2. Scroll Progress Bar & Scroll Spy Active State
        var progressBar = document.getElementById('scroll-progress');
        var sections = document.querySelectorAll('section[id]');
        var navLinks = document.querySelectorAll('.nav-links a, .mobile-nav a');
        var headerOffset = 80;

        function handleScroll() {
          // Scroll Progress Bar
          if (progressBar) {
            var winScroll = document.documentElement.scrollTop || document.body.scrollTop;
            var height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            var scrolled = height > 0 ? (winScroll / height) * 100 : 0;
            progressBar.style.width = scrolled + '%';
          }

          // Scroll Spy Navigation
          var scrollPos = window.scrollY || document.documentElement.scrollTop || document.body.scrollTop;
          
          // If close to the top, remove active state
          if (scrollPos < 100) {
            navLinks.forEach(function(link) {
              link.classList.remove('active');
            });
            return;
          }

          var activeSectionId = null;
          sections.forEach(function(section) {
            var sectionTop = section.offsetTop - headerOffset - 20;
            var sectionHeight = section.offsetHeight;
            var sectionId = section.getAttribute('id');

            if (scrollPos >= sectionTop && scrollPos < sectionTop + sectionHeight) {
              activeSectionId = sectionId;
            }
          });

          if (activeSectionId) {
            navLinks.forEach(function(link) {
              var href = link.getAttribute('href');
              if (href === '#' + activeSectionId || href === '/#' + activeSectionId) {
                link.classList.add('active');
              } else {
                link.classList.remove('active');
              }
            });
          }
        }

        window.addEventListener('scroll', handleScroll, { passive: true });
        // Run once on load to sync initial states
        handleScroll();

        // 3. Mouse spotlight coordination (only on non-touch devices for performance)
        var isTouchDevice = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
        if (!isTouchDevice) {
          document.addEventListener('mousemove', function(e) {
            var cards = document.querySelectorAll('.spotlight-card');
            cards.forEach(function(card) {
              var rect = card.getBoundingClientRect();
              var x = e.clientX - rect.left;
              var y = e.clientY - rect.top;
              card.style.setProperty('--mouse-x', x + 'px');
              card.style.setProperty('--mouse-y', y + 'px');
            });
          });
        }
      })();
    </script>
  </body>
</html>
