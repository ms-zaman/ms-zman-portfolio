---
import type { ImageMetadata } from 'astro';
import defaultFeaturedImage from '../images/ms-zaman-featured-img.webp';

interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  canonicalPath?: string;
  ogImage?: string | ImageMetadata;
}

const {
  title = 'MS Zaman — Frontend Developer | React & WordPress Specialist',
  description = 'MS Zaman — Frontend Developer based in Dhaka, Bangladesh. 5+ years building web interfaces across React, Tailwind CSS, WordPress, and Shopify.',
  ogTitle = 'MS Zaman — Frontend Developer | React & WordPress Specialist',
  ogDescription = '5+ years building web interfaces across React, Tailwind CSS, WordPress, Shopify Liquid, and page builder ecosystems.',
  canonicalPath = '/',
  ogImage = defaultFeaturedImage,
} = Astro.props;

import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

const canonicalURL = new URL(canonicalPath, Astro.site);
const ogImageSrc = typeof ogImage === 'string' ? ogImage : ogImage.src;
const ogImageWidth = typeof ogImage === 'string' ? undefined : ogImage.width;
const ogImageHeight = typeof ogImage === 'string' ? undefined : ogImage.height;
const ogImageURL = new URL(ogImageSrc, Astro.site);
const gaId = import.meta.env.PUBLIC_GA_ID || 'G-FL57VDMLD8';
---

<!doctype html>
<html lang="en">
  <head>
    {gaId && (
      <>
        <!-- Google tag (gtag.js) -->
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0b0b0b" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    {ogImageWidth && <meta property="og:image:width" content={ogImageWidth.toString()} />}
    {ogImageHeight && <meta property="og:image:height" content={ogImageHeight.toString()} />}
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="MS Zaman Portfolio" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImageURL} />

    <title>{title}</title>

    <!-- Theme Initialization: Prevents flash of unstyled content (FOUC) -->
    <script is:inline>
      (function() {
        try {
          var savedTheme = localStorage.getItem('theme');
          if (savedTheme === 'light') {
            document.documentElement.setAttribute('data-theme', 'light');
          } else if (savedTheme === 'dark') {
            document.documentElement.removeAttribute('data-theme');
          } else {
            if (window.matchMedia('(prefers-color-scheme: light)').matches) {
              document.documentElement.setAttribute('data-theme', 'light');
            }
          }
        } catch (e) {}
      })();
    </script>

    <!--
      PERFORMANCE: Non-render-blocking font loading strategy.
      1. Preconnect to font origins.
      2. Load fonts with media="print" + onload swap.
      3. <noscript> fallback for non-JS crawlers.
    -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;1,9..40,400&family=DM+Mono:wght@400;500&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;1,9..40,400&family=DM+Mono:wght@400;500&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;1,9..40,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
    </noscript>
    <ClientRouter />
  </head>
  <body>
    <div id="cursor" class="cursor" aria-hidden="true">
      <div class="cursor-dot"></div>
      <div class="cursor-ring"></div>
    </div>
    <div id="scroll-progress" class="scroll-progress-bar" aria-hidden="true"></div>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Navigation />
    <main id="main-content" class="main-content">
      <slot />
    </main>
    <Footer />

    <!-- Interactive micro-effects — vanilla JS for speed and zero dependencies -->
    <script is:inline>
      document.addEventListener('astro:page-load', function() {
        // 1. Scroll progress bar
        function handleScroll() {
          var progressBar = document.getElementById('scroll-progress');
          if (!progressBar) return;
          var winScroll = document.documentElement.scrollTop || document.body.scrollTop;
          var height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
          var scrolled = height > 0 ? (winScroll / height) * 100 : 0;
          progressBar.style.width = scrolled + '%';
        }

        window.removeEventListener('scroll', window.__handleScroll);
        window.__handleScroll = handleScroll;
        window.addEventListener('scroll', window.__handleScroll, { passive: true });
        handleScroll();

        // 2. Custom cursor logic (desktop pointer:fine devices only)
        var isFinePointer = window.matchMedia('(pointer: fine)').matches;
        if (isFinePointer) {
          if (!window.__cursorInitialized) {
            window.__cursorInitialized = true;
            window.__mouseX = 0;
            window.__mouseY = 0;
            window.__ringX = 0;
            window.__ringY = 0;
            window.__cursorHasMoved = false;

            document.addEventListener('mousemove', function(e) {
              if (!window.__cursorHasMoved) {
                window.__cursorHasMoved = true;
                var cursorEl = document.getElementById('cursor');
                if (cursorEl) cursorEl.style.opacity = '1';
              }
              window.__mouseX = e.clientX;
              window.__mouseY = e.clientY;
              var dotEl = document.querySelector('.cursor-dot');
              if (dotEl) {
                dotEl.style.transform = 'translate(calc(-50% + ' + window.__mouseX + 'px), calc(-50% + ' + window.__mouseY + 'px))';
              }
            }, { passive: true });

            function animateRing() {
              window.__ringX += (window.__mouseX - window.__ringX) * 0.12;
              window.__ringY += (window.__mouseY - window.__ringY) * 0.12;
              var ringEl = document.querySelector('.cursor-ring');
              if (ringEl) {
                ringEl.style.transform = 'translate(calc(-50% + ' + window.__ringX + 'px), calc(-50% + ' + window.__ringY + 'px))';
              }
              requestAnimationFrame(animateRing);
            }
            requestAnimationFrame(animateRing);

            document.addEventListener('mouseover', function(e) {
              var target = e.target;
              while (target && target !== document.body) {
                if (target.tagName === 'A' || target.tagName === 'BUTTON' || target.getAttribute('role') === 'button' || target.classList.contains('copyable')) {
                  var type = target.classList.contains('btn') ? 'button' : 'link';
                  document.body.classList.add('cursor-on-' + type);
                  return;
                }
                target = target.parentNode;
              }
            });

            document.addEventListener('mouseout', function(e) {
              var target = e.target;
              while (target && target !== document.body) {
                if (target.tagName === 'A' || target.tagName === 'BUTTON' || target.getAttribute('role') === 'button' || target.classList.contains('copyable')) {
                  document.body.classList.remove('cursor-on-link', 'cursor-on-button');
                  return;
                }
                target = target.parentNode;
              }
            });

            document.addEventListener('mouseleave', function() {
              var cursorEl = document.getElementById('cursor');
              if (cursorEl) cursorEl.style.opacity = '0';
            });
            document.addEventListener('mouseenter', function() {
              if (window.__cursorHasMoved) {
                var cursorEl = document.getElementById('cursor');
                if (cursorEl) cursorEl.style.opacity = '1';
              }
            });
          }
        }
      });
    </script>
  </body>
</html>
