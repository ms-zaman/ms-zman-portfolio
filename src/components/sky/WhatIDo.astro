---
/**
 * WhatIDo — the "What I do" band: a positioning statement + three proof stats.
 * Ported from the frozen prototype (redesign/variant-g §What I do, #about).
 */
import Eyebrow from './Eyebrow.astro';

const stats = [
  { n: '700K+', accent: true, l: "people build on templates I've shipped" },
  { n: '45+', accent: false, l: 'production templates live on Templately' },
  { n: '5+ yrs', accent: false, l: 'frontend experience across 4 companies' },
];
---
<section class="[ region ] [ border-top-line ]" id="about">
  <div class="[ wrapper ]">
    <div class="[ whatido ] [ grid ]">
      <div class="[ wi-intro ] [ flow ] [ reveal ]">
        <Eyebrow>What I do</Eyebrow>
        <p class="[ whatido-meta ] [ text-ink-3 ]">Dhaka · GMT+6<br />Freelance &amp; contract</p>
      </div>
      <h2 class="[ statement ] [ font-display ] [ reveal ]">
        I turn designs into web experiences that feel <span class="hl">obvious</span> —
        <span class="dim">fast to load, easy to use, and built to hold up on every screen.</span>
      </h2>
    </div>

    <div class="[ stats ] [ grid ] [ border-top-line reveal ]">
      {stats.map((s) => (
        <div>
          <b>{s.accent ? <i>{s.n}</i> : s.n}</b>
          <span>{s.l}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Block = component-specific visual treatment only. Layout comes from the
     Composition classes in the markup (.grid/.flow), the section divider from a
     Utility (.border-top-line); exact spacing is pinned via each primitive's hook. */
  .whatido {
    --grid-space: 30px;              /* .grid gutter (was gap: 30px) */
    grid-template-columns: 1fr 1.6fr;
    align-items: start;
  }

  .wi-intro { --flow-space: 22px; }  /* .flow rhythm (was .whatido-meta margin-top) */

  .whatido-meta {
    font-size: 13px;
    line-height: 1.6;
  }

  .statement {
    font-weight: 500;
    font-size: clamp(25px, 3.4vw, 40px);
    line-height: 1.3;
    letter-spacing: -.01em;
    max-width: 22ch;               /* one-off measure — stays in the Block */
    margin: 0 0 0 auto;
  }
  .statement .hl { color: var(--accent); font-style: italic; }
  .statement .dim { color: var(--ink-3); }

  .stats {
    --grid-space: 26px;              /* .grid gutter (was gap: 26px) */
    grid-template-columns: repeat(3, 1fr);
    margin-top: 64px;
    padding-top: 44px;
  }
  .stats b {
    display: block;
    font-family: var(--display);
    font-weight: 600;
    font-size: clamp(32px, 4vw, 48px);
    letter-spacing: -.02em;
    line-height: 1;
    color: var(--ink);
    margin-bottom: 8px;
  }
  .stats b i { font-style: normal; color: var(--accent); }
  .stats span {
    display: block;
    font-size: 14px;
    color: var(--ink-2);
    line-height: 1.45;
    max-width: 24ch;
  }
  .stats > div:not(:first-child) {
    border-left: 1px solid var(--line);
    padding-left: 26px;
  }

  @media (max-width: 820px) {
    .whatido { grid-template-columns: 1fr; --grid-space: 16px; }
    .statement { margin: 0; }
  }
  @media (max-width: 680px) {
    .stats { grid-template-columns: 1fr; --grid-space: 22px; }
    .stats > div:not(:first-child) { border-left: none; padding-left: 0; }
  }
</style>
