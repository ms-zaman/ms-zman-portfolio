---
/** Tag — small chip. Variant is a CUBE Exception on data-variant:
 *  soft (accent, default) · glass (over sky). */
interface Props { variant?: 'soft' | 'glass'; class?: string; }
const { variant = 'soft', class: className = '' } = Astro.props;
---
<span class:list={['tag', className]} data-variant={variant}><slot /></span>

<style>
  .tag {
    display: inline-flex;
    align-items: center;
    font-size: 12px;
    line-height: 1.4;
    padding: 4px 11px;
    border-radius: var(--r-sm);
  }
  /* Exceptions — variant deviations, keyed on data-variant */
  .tag[data-variant="soft"] { color: var(--accent); background: var(--accent-soft); }
  .tag[data-variant="glass"] {
    font-size: 12.5px;
    color: #2c3e56;
    background: rgba(255, 255, 255, .92);
    border: 1px solid #fff;
    padding: 6px 12px;
    border-radius: 9px;
  }
</style>
