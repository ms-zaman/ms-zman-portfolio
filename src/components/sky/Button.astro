---
/**
 * Button — pill CTA. Renders <a> when `href` is set, else <button>.
 * Block = the `.btn` pill; the variant is a CUBE Exception on `data-variant`:
 *   solid (dark, default) · glass (over sky) · accent (blue).
 */
interface Props {
  href?: string;
  variant?: 'solid' | 'glass' | 'accent';
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  [key: string]: unknown;
}
const { href, variant = 'solid', type = 'button', class: className = '', ...rest } = Astro.props;
const Tag = href ? 'a' : 'button';
---
<Tag
  class:list={['btn', className]}
  data-variant={variant}
  href={href}
  type={href ? undefined : type}
  {...rest}
>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--sans);
    font-size: 15px;
    font-weight: 500;
    line-height: 1;
    padding: 13px 22px;
    border: 0;
    border-radius: var(--r-pill);
    cursor: pointer;
    transition: .22s;
  }
  /* Exceptions — variant deviations, keyed on data-variant */
  .btn[data-variant="solid"] { background: var(--ink); color: #fff; }
  .btn[data-variant="solid"]:hover { background: var(--accent); transform: translateY(-2px); box-shadow: 0 12px 26px rgba(30, 70, 130, .24); }

  .btn[data-variant="glass"] {
    background: rgba(255, 255, 255, .78);
    border: 1px solid #fff;
    color: var(--ink);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  .btn[data-variant="glass"]:hover { background: #fff; transform: translateY(-2px); }

  .btn[data-variant="accent"] { background: var(--accent); color: #fff; }
  .btn[data-variant="accent"]:hover { background: #255f9f; transform: translateY(-2px); box-shadow: 0 12px 26px rgba(30, 70, 130, .24); }
</style>
