---
/**
 * SiteFooter — the light Sky-theme footer for the redesigned homepage.
 * Ported from the frozen prototype (redesign/variant-g footer).
 */
const year = new Date().getFullYear();
---
<footer class="[ sky-footer ] [ wrapper repel ] [ border-top-line ]">
  <span>© {year} MS Zaman</span>
  <nav class="[ sf-nav ] [ cluster ]" aria-label="Footer">
    <a href="/blog">Blog</a>
    <a href="/#contact">Contact</a>
    <a href="https://github.com/ms-zaman" target="_blank" rel="noopener">GitHub</a>
  </nav>
  <span>Web Developer · Dhaka</span>
</footer>

<style>
  /* Layout = .repel (footer row) + .cluster (nav) + .border-top-line utility. */
  .sky-footer {
    --repel-space: 10px 24px;
    padding: 30px 40px;
    font-size: 13px;
    color: var(--ink-3);
  }
  .sf-nav { --cluster-space: 20px; }
  .sf-nav a { color: var(--ink-2); transition: color .2s; }
  .sf-nav a:hover { color: var(--accent); }
</style>
