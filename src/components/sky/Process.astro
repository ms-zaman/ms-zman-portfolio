---
/**
 * Process — a four-step "how we'll work together" grid.
 * Ported from the frozen prototype (redesign/variant-g §Process, #process).
 */
import SectionHead from './SectionHead.astro';

const steps = [
  { n: '1', title: 'Discovery', body: 'We talk through your goals, scope, and references. I map out what success looks like and give you a clear timeline and quote.' },
  { n: '2', title: 'Design', body: 'Wireframes to polished UI — or I build straight from your existing Figma. You review and sign off before a line of production code.' },
  { n: '3', title: 'Build', body: 'Clean, responsive, accessible code with regular live previews. You watch it come together, so there are no surprises at the end.' },
  { n: '4', title: 'Launch', body: 'Cross-browser testing, performance tuning, and deployment — plus a handover so you can edit and run the site yourself.' },
];
---
<section class="section" id="process">
  <div class="sky-wrap">
    <SectionHead
      eyebrow="Process"
      title="How we'll work together"
      sub="A simple, transparent flow — you always know what's happening and see progress along the way."
    />
    <div class="proc-grid">
      {steps.map((s) => (
        <div class="proc reveal">
          <div class="proc-n">{s.n}</div>
          <h3>{s.title}</h3>
          <p>{s.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .proc-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; margin-top: 8px; }
  .proc { padding: 26px 22px; border-radius: 18px; border: 1px solid var(--line); background: var(--paper); }
  .proc-n {
    font-family: var(--display);
    font-weight: 600;
    font-size: 15px;
    color: var(--accent);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--accent-soft);
    margin-bottom: 16px;
  }
  .proc h3 { font-family: var(--display); font-weight: 600; font-size: 18px; letter-spacing: -.01em; margin-bottom: 8px; }
  .proc p { font-size: 14px; color: var(--ink-2); line-height: 1.55; }

  @media (max-width: 820px) { .proc-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 520px) { .proc-grid { grid-template-columns: 1fr; } }
</style>
