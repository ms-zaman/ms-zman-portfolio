---
/**
 * Hero — the immersive sky header.
 * The sky background is parameterised via CSS variables (--sun-x/-y, --sun-glow,
 * --sky-tint) so the SkyEngine can later drive it from real time & weather.
 * With the default token values it renders as a clear midday sky.
 */
import Button from './Button.astro';
import Tag from './Tag.astro';
import HeroSky from './hero-sky/HeroSky';

const stack = ['React', 'WordPress', 'Shopify', 'Tailwind'];
const industries = ['SaaS', 'E-commerce', 'Agencies'];
const stats = [
  { n: '700K+', l: 'users' },
  { n: '45+', l: 'templates' },
  { n: '5 yrs', l: 'experience' },
];
const birds = [
  { cls: 'b1', dur: '0.5s' },
  { cls: 'b2', dur: '0.42s' },
  { cls: 'b3', dur: '0.55s' },
  { cls: 'b4', dur: '0.46s' },
];
---
<header class="hero">
  <!-- R3F weather island: renders the live sky in WebGL above the CSS photo poster.
       client:only (no SSR) — the poster below covers the pre-hydration paint. -->
  <HeroSky client:only="react" />

  <!-- the sun (CSS poster; hidden at night and once WebGL owns the sky) -->
  <div class="sun" aria-hidden="true"><span class="sun-core"></span></div>

  <!-- drifting cloud cut-outs (CSS poster; hidden once WebGL owns the sky) -->
  <div class="cloud a"><div class="bob"><img src="/sky/cloud-1.png" alt="" loading="eager" /></div></div>
  <div class="cloud b"><div class="bob"><img src="/sky/cloud-2.png" alt="" loading="eager" /></div></div>
  <div class="cloud c"><div class="bob"><img src="/sky/cloud-2.png" alt="" loading="eager" /></div></div>
  <div class="cloud d"><div class="bob"><img src="/sky/cloud-1.png" alt="" loading="eager" /></div></div>
  <div class="cloud e"><div class="bob"><img src="/sky/cloud-1.png" alt="" loading="eager" /></div></div>

  <!-- flapping birds (SMIL) -->
  {birds.map((b) => (
    <div class={`bird ${b.cls}`}>
      <svg viewBox="0 0 44 26"><path fill="none" stroke="#274a6b" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" d="M2 15 Q12 3 22 12 Q32 3 42 15">
        <animate attributeName="d" dur={b.dur} repeatCount="indefinite" values="M2 15 Q12 3 22 12 Q32 3 42 15;M2 13 Q12 15 22 11 Q32 15 42 13;M2 15 Q12 3 22 12 Q32 3 42 15" />
      </path></svg>
    </div>
  ))}

  <nav class="nav" aria-label="Primary">
    <div class="nav-in">
      <span class="nav-brand"><span class="mono">MZ</span>MS Zaman</span>
      <span class="nav-links">
        <a href="#services">Services</a><a href="#work">Work</a><a href="/blog">Blog</a><a href="#faq">FAQ</a><a href="#contact">Contact</a>
      </span>
      <a href="#contact" class="nav-cta">Let's talk</a>
      <button type="button" class="nav-burger" aria-label="Open menu" aria-expanded="false" aria-controls="nav-menu">
        <span class="nav-burger-box" aria-hidden="true"><span></span><span></span><span></span></span>
      </button>
      <div class="nav-menu" id="nav-menu" hidden>
        <a href="#services">Services</a>
        <a href="#work">Work</a>
        <a href="/blog">Blog</a>
        <a href="#faq">FAQ</a>
        <a href="#contact">Contact</a>
      </div>
    </div>
  </nav>

  <div class="sky-wrap hero-grid" id="content" tabindex="-1">
    <div class="greet">Hey, I'm MS Zaman — web developer in Dhaka</div>
    <h1 class="h1">Building web experiences that just <span class="u"><em>work</em></span>.</h1>

    <div class="hero-lower">
      <div>
        <p class="intro">Shipping production sites across <b>React</b>, <b>WordPress</b> &amp; <b>Shopify</b> — plus page-builder templates used by <b>700K+</b> people.</p>
        <div class="cta-row">
          <Button href="#work" variant="solid">View work <span aria-hidden="true">→</span></Button>
          {/* TODO(résumé): placeholder — restore the real "Résumé (PDF)" button once the PDF exists */}
          <Button href="#contact" variant="glass">Get in touch</Button>
          <span class="socials">
            <a href="https://github.com/ms-zaman" target="_blank" rel="noopener" aria-label="GitHub"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0C6.5 2.8 5.4 3.1 5.4 3.1a4.2 4.2 0 0 0-.1 3.2A4.6 4.6 0 0 0 4 9.5c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2V21" /></svg></a>
            <a href="https://www.linkedin.com/in/sharfuzzaman/" target="_blank" rel="noopener" aria-label="LinkedIn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4m0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2z" /><path d="M8 11v5" /><path d="M8 8v.01" /><path d="M12 16v-5" /><path d="M16 16v-3a2 2 0 0 0-4 0" /></svg></a>
          </span>
        </div>
      </div>

      <div class="glance">
        <p class="g-label">Stack</p>
        <div class="g-tags">{stack.map((t) => <Tag variant="glass">{t}</Tag>)}</div>
        <p class="g-label">Industries</p>
        <div class="g-tags">{industries.map((t) => <Tag variant="glass">{t}</Tag>)}</div>
        <div class="g-stats">
          {stats.map((s) => <div><b>{s.n}</b><span>{s.l}</span></div>)}
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  .hero {
    position: relative;
    min-height: calc(100vh - 120px); ;
    overflow: hidden;
    background:
      url('/sky/sky.avif') center top / cover no-repeat,
      linear-gradient(180deg, var(--sky-1) 0%, var(--sky-2) 44%, var(--sky-3) 66%, var(--sky-4) 82%, var(--horizon) 100%);
  }
  /* atmosphere — sun glow (position + colour driven by SkyEngine) + optional tint */
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(180deg, var(--sky-tint), var(--sky-tint-2)),
      radial-gradient(38% 34% at var(--sun-x) var(--sun-y), var(--sun-glow), rgba(255, 240, 205, .28) 42%, rgba(255, 240, 205, 0) 66%);
    transition: background 1.2s ease, opacity 1.2s ease;
  }
  /* Legibility scrim so white type reads over the clouds, feathering to white at the
     bottom. This belongs to the photo hero (the prototype's sunny sky) — it was
     switched off site-wide because it muddied the WebGL sky, but the photo needs it:
     without it the intro copy sits on the photo's bright lower half at 1.69:1.
     So it is on by default (which is also the pre-hydration state, where the poster
     is what's showing) and switched off below as soon as a non-sunny condition is
     published, since those are rendered by the canvas. */
  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 4;
    pointer-events: none;
    background:
      linear-gradient(100deg, rgba(14, 38, 74, .42) 0%, rgba(14, 38, 74, .16) 40%, rgba(14, 38, 74, 0) 64%),
      radial-gradient(150% 80% at 88% 116%, rgba(255, 255, 255, .95) 0%, rgba(255, 255, 255, 0) 58%),
      linear-gradient(180deg, rgba(255, 255, 255, 0) 58%, rgba(255, 255, 255, .6) 80%, rgba(255, 255, 255, .92) 93%, var(--horizon) 100%);
    transition: opacity 1.2s ease;
  }
  /* every condition except sunny is the WebGL sky — keep it unmuddied */
  :global(:root[data-sky-weather]:not([data-sky-weather="sunny"])) .hero::after {
    background: none;
  }

  /* R3F weather island — above the photo poster (base), below the atmosphere/scrim.
     :global() is required because this div is rendered by React, so it never gets
     Astro's scoped-style attribute. */
  .hero :global(.hero-sky) {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0;
    transition: opacity 1.2s ease;
    pointer-events: none;
  }
  .hero :global(.hero-sky.ready) { opacity: 1; }
  .hero :global(.hero-sky canvas) { display: block; width: 100% !important; height: 100% !important; }

  /* once WebGL owns the sky, retire the CSS poster clouds + atmosphere glow + sun
     (birds stay) — the canvas draws its own sun, veiled by whatever deck it has */
  .hero.sky-webgl .cloud { display: none; }
  .hero.sky-webgl::before { opacity: 0; }
  .hero.sky-webgl .sun { opacity: 0; }

  /* ── the sun ────────────────────────────────────────────────────────────────
     The daytime counterpart to the WebGL moon: a core disc, a corona, and two
     counter-rotating ray fans. Four things worth knowing:

     • Horizontal position is the real solar arc (--sun-x, 6% → 94% between
       sunrise and sunset), so the sun genuinely tracks the visitor's day.
     • Vertical position is *not* --sun-y. That runs to 60% at sunrise, which
       lands the disc in the middle of the headline. The hero photo looks
       straight up — there is no horizon in frame, so a low sun wouldn't read as
       low anyway. Instead the disc lives in the clear band between the nav pill
       and the greet line, in px (both of those are px-anchored, so a % would
       drift into them on a taller viewport). The wide --sun-y glow on ::before
       still sinks to the horizon at dawn/dusk — that's what tells the time.
     • z-index 1 puts it under the drifting cloud cut-outs (z 2), so rafts pass
       in front of it, the way the clouds pass in front of the WebGL moon.
     • Colour follows data-sky-phase; at night it's simply gone.               */
  .sun {
    --core: #fffdf7;
    --halo-1: rgba(255, 247, 224, .92);
    --halo-2: rgba(255, 236, 190, .42);
    --halo-3: rgba(255, 226, 165, .16);
    --ray: rgba(255, 248, 226, .44);
    --band: 122px;   /* nav pill ends at 84px, the greet line starts at 160px */
    --size: 42px;
    --corona: 380px;

    position: absolute;
    z-index: 1;
    pointer-events: none;
    left: var(--sun-x);
    top: var(--band);
    width: var(--corona);
    height: var(--corona);
    margin: calc(var(--corona) / -2) 0 0 calc(var(--corona) / -2);
    transition: opacity 1.2s ease, left 1.2s ease;
  }
  /* corona — the wide warm bloom the disc sits inside. It deliberately starts at
     the *mid* halo, not the bright one: filling the centre with --halo-1 makes the
     surround as bright as the core, and the disc stops reading as the light source
     (worst on phones, where the disc is 24px inside a 210px wash). The hot centre
     is the core's own box-shadow instead. */
  .sun::before,
  .sun::after,
  .sun-core { content: ""; position: absolute; inset: 0; border-radius: 50%; }
  .sun::before {
    background: radial-gradient(closest-side, var(--halo-2) 0%, var(--halo-2) 9%, var(--halo-3) 30%, transparent 68%);
    animation: sun-breathe 9s ease-in-out infinite;
  }
  /* ray fan — two layers at different counts and speeds so the pattern never
     resolves into an obvious repeat. Masked to a ring so the rays emerge from
     outside the disc and fade before the corona's edge. */
  .sun::after {
    background: repeating-conic-gradient(from 0deg, var(--ray) 0deg 2.6deg, transparent 2.6deg 17deg);
    -webkit-mask-image: radial-gradient(closest-side, transparent 7%, #000 24%, transparent 58%);
    mask-image: radial-gradient(closest-side, transparent 7%, #000 24%, transparent 58%);
    filter: blur(4px);
    animation: sun-turn 240s linear infinite;
  }
  /* core disc — small and blown out, the way a real sun is. The stops hold pure
     white most of the way across before falling off fast: a slow ramp from the
     centre reads as a cotton ball, not a light source. The box-shadows are the
     tight bloom that keeps the edge from looking like a pasted-on circle. */
  .sun-core {
    inset: calc((var(--corona) - var(--size)) / 2);
    background: radial-gradient(circle, #fff 0%, #fff 46%, var(--core) 66%, var(--halo-1) 84%, rgba(255, 222, 158, .45) 100%);
    /* keyed off --size so the bloom shrinks with the disc: at a fixed px radius a
       26px phone sun turns into a diffuse smudge with no core left in it */
    box-shadow:
      0 0 calc(var(--size) * .33) calc(var(--size) * .07) #fff,
      0 0 calc(var(--size) * .72) calc(var(--size) * .24) var(--halo-1),
      0 0 calc(var(--size) * 1.7) calc(var(--size) * .52) var(--halo-2),
      0 0 calc(var(--size) * 3.6) calc(var(--size) * 1.2) var(--halo-3);
  }
  @keyframes sun-turn { to { transform: rotate(360deg); } }
  @keyframes sun-breathe { 0%, 100% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.045); opacity: .9; } }

  /* dawn/dusk: bigger, lower-contrast, and much warmer — a sun seen through
     more atmosphere. Night: no sun at all (the WebGL moon has the sky). */
  /* dawn runs hotter than dusk on purpose: the sun is on the left then, which is
     the strong end of the legibility scrim, and the scrim paints over it (z 4 vs 1).
     Without the extra headroom a sunrise reads as a grey smudge. */
  :global(:root[data-sky-phase="dawn"]) .sun {
    --core: #fff7e8; --halo-1: rgba(255, 232, 196, 1); --halo-2: rgba(255, 198, 150, .56);
    --halo-3: rgba(255, 176, 126, .22); --ray: rgba(255, 220, 180, .36); --size: 62px;
  }
  :global(:root[data-sky-phase="dusk"]) .sun {
    --core: #ffeccb; --halo-1: rgba(255, 206, 156, .96); --halo-2: rgba(255, 162, 106, .5);
    --halo-3: rgba(255, 138, 88, .2); --ray: rgba(255, 196, 142, .3); --size: 64px;
  }
  :global(:root[data-sky-phase="night"]) .sun { display: none; }

  /* ── sky picker ─────────────────────────────────────────────────────────────
     The live-weather chip and its menu. Rendered by React (SkyPicker.tsx), so it
     never gets Astro's scoped-style attribute — hence :global() throughout, the
     same as .hero-sky above. z-index 12 puts it over the legibility scrim (4) and
     the copy (10); it is the one thing in the hero that takes a click. The menu
     opens *upward* because the chip sits at the bottom of the hero. */
  .hero :global(.sky-pick) {
    position: absolute;
    z-index: 12;
    right: 20px;
    bottom: 26px;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
  }
  .hero :global(.sky-chip) {
    display: inline-flex; align-items: center; gap: 8px;
    position: relative; /* anchors the one-time hint ring */
    padding: 8px 12px 8px 11px; border-radius: var(--r-pill);
    font: inherit; font-size: 13px; color: var(--ink); cursor: pointer;
    background: var(--glass); border: 1px solid var(--glass-line);
    backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
    box-shadow: 0 10px 30px rgba(40, 80, 140, .12);
    transition: background .2s, transform .2s, box-shadow .2s;
  }
  .hero :global(.sky-chip:hover) { background: rgba(255, 255, 255, .78); transform: translateY(-1px); }
  .hero :global(.sky-chip svg) { width: 17px; height: 17px; color: var(--ink-2); flex: none; }
  /* the "this is live" tell — a slow pulse, so it reads as a status light and not
     as something asking to be clicked */
  .hero :global(.sky-live) {
    width: 6px; height: 6px; border-radius: 50%; flex: none;
    background: #35c07a; box-shadow: 0 0 0 3px rgba(53, 192, 122, .18);
    animation: sky-pulse 2.6s ease-in-out infinite;
  }
  @keyframes sky-pulse { 0%, 100% { opacity: 1; } 50% { opacity: .35; } }
  /* …and the word, because a pulsing dot on its own reads as decoration. Set in
     the small-caps of the menu's group headings so it stays a label, not copy. */
  .hero :global(.sky-live-t) {
    margin-left: -3px; /* sits with its dot, not evenly between both neighbours */
    font-family: var(--sans); font-size: 10px; font-weight: 600;
    letter-spacing: .14em; text-transform: uppercase; color: var(--ink-2);
  }

  /* The "you can click this" tell. Resting, the chip is a statement about the
     sky; the caret only turns up on hover/focus, and it holds its 12px whether
     it's visible or not so nothing reflows under the cursor. */
  .hero :global(.sky-cue) {
    display: inline-flex; margin-left: -2px; color: var(--ink-3);
    opacity: 0; transform: translateY(2px);
    transition: opacity .2s, transform .2s;
  }
  .hero :global(.sky-cue svg) { width: 12px; height: 12px; color: inherit; }
  .hero :global(.sky-chip:hover .sky-cue),
  .hero :global(.sky-chip:focus-visible .sky-cue) { opacity: .8; transform: none; }
  /* open = the menu is already up there, so flip it and stop hiding */
  .hero :global(.sky-chip[aria-expanded="true"] .sky-cue) { opacity: .8; transform: rotate(180deg); }

  /* The one-time "notice me" (SkyPicker gates it on localStorage, once per
     browser): one soft bounce, and a ring breathing out of the chip's own edge.
     The ring is two-toned on purpose — a white edge for the dawn/day skies and
     an ink one just behind it for the night skies, so whichever one the sky
     swallows, the other still draws. */
  .hero :global(.sky-chip.hint) { animation: sky-hint 1.5s cubic-bezier(.34, 1.36, .64, 1) both; }
  .hero :global(.sky-chip.hint::after) {
    content: ''; position: absolute; inset: -1px;
    border-radius: inherit; pointer-events: none;
    animation: sky-hint-ring 1.5s ease-out both;
  }
  @keyframes sky-hint {
    0%, 8% { transform: scale(1); }
    34% { transform: scale(1.07); }
    62% { transform: scale(.99); }
    100% { transform: scale(1); }
  }
  @keyframes sky-hint-ring {
    0% { box-shadow: 0 0 0 0 rgba(255, 255, 255, .85), 0 0 0 0 rgba(40, 80, 140, .4); }
    100% { box-shadow: 0 0 0 14px rgba(255, 255, 255, 0), 0 0 0 20px rgba(40, 80, 140, 0); }
  }

  .hero :global(.sky-menu) {
    width: 208px; padding: 7px; border-radius: 14px;
    background: rgba(255, 255, 255, .82); border: 1px solid rgba(255, 255, 255, .9);
    backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px);
    box-shadow: 0 18px 44px rgba(40, 80, 140, .22);
    animation: sky-rise .18s ease both;
  }
  @keyframes sky-rise { from { opacity: 0; transform: translateY(6px); } }
  .hero :global(.sky-group) { margin-top: 4px; padding-top: 4px; border-top: 1px solid #e7eef6; }
  .hero :global(.sky-group-t) {
    margin: 4px 0 3px; padding: 0 9px;
    font-family: var(--sans); font-size: 10px; font-weight: 600;
    letter-spacing: .16em; text-transform: uppercase; color: #7c8ba0;
  }
  .hero :global(.sky-opt) {
    display: flex; align-items: center; gap: 9px; width: 100%;
    padding: 7px 9px; border: 0; border-radius: 9px; background: none;
    font: inherit; font-size: 13.5px; color: var(--ink); text-align: left; cursor: pointer;
    transition: background .15s;
  }
  .hero :global(.sky-opt svg) { width: 16px; height: 16px; color: var(--ink-3); flex: none; }
  .hero :global(.sky-opt em) { margin-left: auto; font-style: normal; font-size: 11px; color: var(--ink-3); }
  .hero :global(.sky-opt:hover) { background: rgba(40, 80, 140, .07); }
  .hero :global(.sky-opt.on) { background: var(--ink); color: #fff; }
  .hero :global(.sky-opt.on svg), .hero :global(.sky-opt.on em) { color: rgba(255, 255, 255, .75); }
  .hero :global(.sky-chip:focus-visible), .hero :global(.sky-opt:focus-visible) {
    outline: 2px solid var(--accent); outline-offset: 2px;
  }

  @media (max-width: 900px) {
    /* The mobile hero is taller than the viewport (stacked copy + glance card), so
       an absolutely-positioned chip at its bottom edge lands below the fold. Pin it
       to the viewport instead and shrink it to an icon so it doesn't sit on top of
       the copy; SkyPicker's IntersectionObserver drops it once the hero scrolls by. */
    .hero :global(.sky-pick) { position: fixed; right: 16px; bottom: 16px; }
    .hero :global(.sky-pick.gone) { opacity: 0; visibility: hidden; transition: opacity .25s, visibility .25s; }
    .hero :global(.sky-chip) {
      width: 44px; height: 44px; padding: 0; border-radius: 50%;
      justify-content: center; position: relative;
      background: rgba(255, 255, 255, .8);
    }
    .hero :global(.sky-chip svg) { width: 20px; height: 20px; }
    /* icon only — the place/time label has nowhere to go at this width */
    .hero :global(.sky-chip > span:not(.sky-live):not(.sr-only)) { display: none; }
    .hero :global(.sky-live) { position: absolute; top: 7px; right: 7px; }
    .hero :global(.sky-menu) { animation: none; }
  }

  /* clouds */
  .cloud { position: absolute; z-index: 2; pointer-events: none; will-change: transform; }
  .cloud > .bob { will-change: transform; }
  .cloud img { width: 100%; height: auto; display: block; }
  @keyframes cdrift { from { transform: translateX(-40vw); } to { transform: translateX(140vw); } }
  @keyframes cbob { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-13px); } }
  .cloud.a { top: 8%;  width: 460px; opacity: .95; animation: cdrift 95s linear infinite; }
  .cloud.b { top: 26%; width: 260px; opacity: .6;  animation: cdrift 150s linear infinite; animation-delay: -58s; }
  .cloud.c { top: 40%; width: 560px; opacity: .8;  animation: cdrift 120s linear infinite; animation-delay: -82s; }
  .cloud.d { top: 3%;  width: 200px; opacity: .5;  animation: cdrift 180s linear infinite; animation-delay: -26s; }
  .cloud.e { top: 31%; width: 340px; opacity: .65; animation: cdrift 158s linear infinite; animation-delay: -120s; }
  .cloud.a > .bob { animation: cbob 11s ease-in-out infinite; }
  .cloud.b > .bob { animation: cbob 8s ease-in-out infinite; }
  .cloud.c > .bob { animation: cbob 13.5s ease-in-out infinite; }
  .cloud.d > .bob { animation: cbob 9s ease-in-out infinite; }
  .cloud.e > .bob { animation: cbob 10.5s ease-in-out infinite; }

  /* birds */
  .bird { position: absolute; z-index: 3; pointer-events: none; will-change: transform; }
  .bird svg { width: 100%; height: auto; display: block; }
  .bird.b1 { top: 19%; width: 30px; opacity: .62; animation: flyA 32s linear infinite; }
  .bird.b2 { top: 23%; width: 20px; opacity: .5;  animation: flyB 42s linear infinite; animation-delay: -9s; }
  .bird.b3 { top: 15%; width: 26px; opacity: .56; animation: flyA 37s linear infinite; animation-delay: -19s; }
  .bird.b4 { top: 29%; width: 16px; opacity: .42; animation: flyB 50s linear infinite; animation-delay: -31s; }
  @keyframes flyA { 0% { transform: translate(-14vw, 0); } 22% { transform: translate(20vw, -34px); } 48% { transform: translate(50vw, -6px); } 72% { transform: translate(82vw, -40px); } 100% { transform: translate(130vw, -14px); } }
  @keyframes flyB { 0% { transform: translate(-14vw, 14px); } 30% { transform: translate(30vw, -18px); } 56% { transform: translate(62vw, 16px); } 82% { transform: translate(94vw, -24px); } 100% { transform: translate(132vw, 4px); } }

  /* nav — fixed to the viewport so it rides the whole page, not just the hero.
     It still *lives* in the hero markup: the hero is the first thing on the page,
     so `top: 26px` fixed lands on the exact pixel the absolute pill used to at
     scrollTop 0, and .hero-grid's 160px padding-top clears it as before. (The
     hero's overflow:hidden doesn't clip it — nothing up the tree transforms, so
     the containing block is the viewport.) */
  .nav {
    position: fixed; top: 26px; left: 0; right: 0; z-index: 100;
    display: flex; justify-content: center;
    transition: top .28s ease;
  }
  .nav-in {
    position: relative; /* anchors the mobile dropdown menu */
    display: flex; align-items: center; gap: 26px;
    padding: 9px 12px 9px 16px; border-radius: var(--r-pill);
    background: var(--glass); border: 1px solid var(--glass-line);
    backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
    box-shadow: 0 10px 30px rgba(40, 80, 140, .12);
    transition: padding .28s ease, background .28s ease, border-color .28s ease, box-shadow .28s ease;
  }
  /* Past the hero the pill sits on the white sections, where 55% glass over white
     leaves the links washed out and the blur has nothing to bite on. Go near-solid
     and lift it off the page instead. Only the pill moves — it's fixed, so none of
     this can shift the document. */
  .nav.scrolled { top: 16px; }
  .nav.scrolled .nav-in {
    padding: 7px 10px 7px 14px;
    background: rgba(255, 255, 255, .93);
    border-color: rgba(255, 255, 255, .96);
    box-shadow: var(--shadow-md);
  }
  .nav-brand { display: flex; align-items: center; gap: 9px; font-weight: 600; font-size: 15px; color: var(--ink); }
  .nav-brand .mono {
    width: 26px; height: 26px; border-radius: 50%; background: var(--ink); color: #fff;
    display: grid; place-items: center; font-size: 11px; font-weight: 600;
  }
  .nav-links { display: flex; gap: 20px; }
  .nav-links a { font-size: 14px; color: var(--ink-2); transition: color .2s; }
  .nav-links a:hover { color: var(--ink); }
  .nav-cta { font-size: 13.5px; font-weight: 500; color: #fff; background: var(--ink); padding: 8px 15px; border-radius: var(--r-pill); transition: .2s; }
  .nav-cta:hover { background: var(--accent); }

  /* hamburger — desktop-hidden; the ≤760 query below reveals it. Three bars that
     fold into an × on open (state driven by aria-expanded). */
  .nav-burger {
    display: none;
    align-items: center; justify-content: center;
    width: 38px; height: 38px; margin: -4px -4px -4px 0;
    padding: 0; border: 0; background: none; cursor: pointer;
    color: var(--ink); border-radius: 50%;
    -webkit-tap-highlight-color: transparent;
    transition: background .2s;
  }
  .nav-burger:hover { background: rgba(40, 80, 140, .07); }
  .nav-burger-box { position: relative; width: 18px; height: 12px; }
  .nav-burger-box span {
    position: absolute; left: 0; right: 0; height: 2px; border-radius: 2px;
    background: currentColor;
    transition: top .28s ease, transform .28s ease, opacity .18s ease;
  }
  .nav-burger-box span:nth-child(1) { top: 0; }
  .nav-burger-box span:nth-child(2) { top: 5px; }
  .nav-burger-box span:nth-child(3) { top: 10px; }
  .nav-burger[aria-expanded="true"] .nav-burger-box span:nth-child(1) { top: 5px; transform: rotate(45deg); }
  .nav-burger[aria-expanded="true"] .nav-burger-box span:nth-child(2) { opacity: 0; }
  .nav-burger[aria-expanded="true"] .nav-burger-box span:nth-child(3) { top: 5px; transform: rotate(-45deg); }

  /* dropdown panel — glass, anchored just under the pill's right edge (matches the
     sky-menu / picker language) */
  .nav-menu {
    position: absolute; top: calc(100% + 10px); right: 0;
    min-width: 208px; padding: 8px;
    display: flex; flex-direction: column;
    border-radius: 16px;
    /* near-solid (like .nav.scrolled) so the links stay legible over a busy hero
       even where backdrop-filter isn't honoured */
    background: rgba(255, 255, 255, .96); border: 1px solid rgba(255, 255, 255, .98);
    backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px);
    box-shadow: 0 18px 44px rgba(40, 80, 140, .22);
    animation: nav-menu-in .18s ease both;
  }
  .nav-menu[hidden] { display: none; }
  .nav-menu a {
    padding: 11px 14px; border-radius: 10px;
    font-size: 15px; color: var(--ink-2);
    transition: background .15s, color .15s;
  }
  .nav-menu a:hover { background: rgba(40, 80, 140, .07); color: var(--ink); }
  .nav-burger:focus-visible, .nav-menu a:focus-visible {
    outline: 2px solid var(--accent); outline-offset: 2px;
  }
  @keyframes nav-menu-in { from { opacity: 0; transform: translateY(-6px); } }

  /* mobile: swap the inline links for the hamburger + dropdown */
  @media (max-width: 760px) {
    .nav-in { gap: 12px; }
    .nav-links { display: none; }
    .nav-burger { display: inline-flex; }
  }

  /* hero content */
  /* fill the hero and center the content block so it stays balanced at any
     viewport height (top padding clears the floating nav) */
  .hero-grid {
    position: relative; z-index: 10;
    min-height: calc(100vh - 120px) ; box-sizing: border-box;
    display: flex; flex-direction: column; justify-content: center;
    padding-top: 160px;
    padding-bottom: 100px;
    
  }
  .greet { display: inline-flex; align-items: center; gap: 9px; font-size: 14px; color: #eaf3ff; text-shadow: 0 1px 3px rgba(18, 44, 84, .5); }
  .h1 {
    font-family: var(--display); font-weight: 600; font-size: clamp(40px, 5.6vw, 72px);
    line-height: 1.04; letter-spacing: -.035em; color: #fff; max-width: 18ch;
    text-shadow: 0 2px 10px rgba(18, 44, 84, .3);
  }
  .h1 em { font-style: italic; color: #fff9ec; }
  .h1 .u { position: relative; white-space: nowrap; }
  .h1 .u::after { content: ""; position: absolute; left: 0; right: 0; bottom: .06em; height: .09em; background: var(--sun); border-radius: 2px; opacity: .9; }

  .hero-lower { display: grid; grid-template-columns: 1.5fr 1fr; gap: 44px; align-items: end; }
  .intro { font-size: 18px; line-height: 1.55; color: #f2f7ff; max-width: 46ch; margin-bottom: 30px; text-shadow: 0 1px 2px rgba(18, 44, 84, .4), 0 2px 22px rgba(18, 44, 84, .28); }
  .intro b { color: #fff; font-weight: 600; }

  /* Cloudy and snow are the pale-sky WebGL conditions with no scrim (sunny keeps its
     own ::after; the rest are dark enough). White type loses contrast on their light
     left/lower band, so lift the shadow at the text layer for just these two — no
     dimming of the hero itself. */
  :global(:root[data-sky-weather="cloudy"]) .greet,
  :global(:root[data-sky-weather="snow"]) .greet { text-shadow: 0 1px 3px rgba(14, 34, 68, .72); }
  :global(:root[data-sky-weather="cloudy"]) .h1,
  :global(:root[data-sky-weather="snow"]) .h1 {
    text-shadow: 0 1px 2px rgba(14, 34, 68, .55), 0 2px 16px rgba(14, 34, 68, .4);
  }
  :global(:root[data-sky-weather="cloudy"]) .intro,
  :global(:root[data-sky-weather="snow"]) .intro {
    text-shadow: 0 1px 2px rgba(14, 34, 68, .6), 0 2px 20px rgba(14, 34, 68, .34);
  }

  .cta-row { display: flex; flex-wrap: wrap; align-items: center; gap: 14px; }
  /* CTA hierarchy — one clear primary. The solid "View work" is lifted and a touch
     larger so it plainly leads; "Get in touch" recedes to a quieter glass. Both keep
     a light fill so their labels stay legible over every sky (a bare text link would
     vanish on the pale cloudy one). */
  .cta-row :global(.btn-solid) {
    padding: 14px 26px;
    box-shadow: 0 10px 24px rgba(18, 44, 84, .28);
  }
  .cta-row :global(.btn-glass) {
    background: rgba(255, 255, 255, .55);
    border-color: rgba(255, 255, 255, .68);
    color: var(--ink-2);
  }
  .cta-row :global(.btn-glass:hover) {
    background: rgba(255, 255, 255, .82);
    color: var(--ink);
  }
  .socials { display: flex; gap: 8px; margin-left: 4px; }
  .socials a {
    width: 40px; height: 40px; border-radius: 50%; display: grid; place-items: center; color: var(--ink);
    background: rgba(255, 255, 255, .72); border: 1px solid #fff; backdrop-filter: blur(10px); transition: .2s;
  }
  .socials a:hover { background: #fff; transform: translateY(-2px); }
  .socials svg { width: 18px; height: 18px; }

  /* at-a-glance card */
  .glance {
    background: rgba(255, 255, 255, .72); border: 1px solid rgba(255, 255, 255, .9);
    backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px);
    border-radius: 16px; padding: 18px 20px; box-shadow: 0 18px 44px rgba(40, 80, 140, .2);
  }
  .glance .g-label { font-family: var(--sans); font-size: 10.5px; letter-spacing: .16em; text-transform: uppercase; color: #5a6b80; font-weight: 600; margin: 0 0 11px; }
  .glance .g-label:not(:first-child) { margin-top: 18px; }
  .g-tags { display: flex; flex-wrap: wrap; gap: 7px; }
  .g-stats { display: flex; gap: 16px; padding-top: 14px; margin-top: 16px; border-top: 1px solid #e7eef6; }
  .g-stats b { display: block; font-family: var(--display); font-weight: 600; font-size: 19px; color: var(--ink); line-height: 1; }
  .g-stats span { font-size: 11px; color: var(--ink-3); }
  .g-stats > div:not(:first-child) { border-left: 1px solid #e7eef6; padding-left: 16px; }

  @media (max-width: 900px) {
    .hero-lower { grid-template-columns: 1fr; }
    /* stacked content is tall — anchor to top so it never hides under the nav */
    .hero-grid { justify-content: flex-start; padding-top: 116px; }
    /* the copy starts 44px higher here (padding-top 116 vs 160), so the clear band
       between the nav pill and the greet is only 84–116px — hence a small disc */
    /* warmer than desktop so the disc separates from the photo's bright cloud, but
       the outer wash is pulled back — the greet line is only 15px below the disc
       here, and a wide bloom was costing it contrast it can't spare */
    .sun { --band: 101px; --size: 28px; --corona: 190px; --halo-2: rgba(255, 228, 168, .46); --halo-3: rgba(255, 214, 140, .1); }
    .sun::after { filter: blur(3px); }
    :global(:root[data-sky-phase="dawn"]) .sun,
    :global(:root[data-sky-phase="dusk"]) .sun { --size: 28px; }
  }
  @media (prefers-reduced-motion: reduce) {
    /* the chip still says its piece, it just doesn't jump up and down about it.
       (SkyPicker checks the same query before ever setting .hint — this is the
       belt to that braces, for a preference flipped after load.) */
    .hero :global(.sky-chip.hint), .hero :global(.sky-chip.hint::after) { animation: none; }
    .hero :global(.sky-cue) { transition: none; }
    /* the nav still goes solid past the hero, it just arrives there instantly */
    .nav, .nav-in { transition: none; }
    .nav-burger, .nav-burger-box span { transition: none; }
    .nav-menu { animation: none; }
    .cloud, .cloud > .bob, .bird { animation: none; }
    .bird svg :global(animate) { display: none; }
    .hero::before { transition: none; }
    .sun::before, .sun::after { animation: none; }
  }
</style>

<script>
  // Flip the fixed nav to its opaque state once the hero's bottom edge has passed
  // under the pill. The hero is its own sentinel: an IntersectionObserver whose
  // root is inset from the top by the pill's height stops seeing the hero at
  // exactly that moment — no scroll handler on every frame, no spacer element to
  // keep in sync with the CSS, and it reports the right state on a reload that
  // restores mid-page scroll.
  const NAV_BOTTOM = 80; // 26px top + the pill's ~46px, rounded up for air

  const nav = document.querySelector('.nav');
  const hero = document.querySelector('.hero');

  if (nav && hero) {
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          // take the newest entry — a batch can hold several for one target
          const e = entries[entries.length - 1];
          nav.classList.toggle('scrolled', !e.isIntersecting);
        },
        { rootMargin: `-${NAV_BOTTOM}px 0px 0px 0px` },
      );
      io.observe(hero);
    } else {
      const onScroll = () =>
        nav.classList.toggle('scrolled', hero.getBoundingClientRect().bottom <= NAV_BOTTOM);
      addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }
  }
</script>

<script>
  // Mobile hamburger — toggles the dropdown menu, keeping aria in sync and closing
  // on Escape, outside-click, or a link tap (the links are same-page jumps, so we
  // just drop the menu behind the navigation). Above 760px the button is
  // display:none so none of this can fire; a resize past that width force-closes it
  // in case it was left open on a rotating/​resizing phone.
  const burger = document.querySelector<HTMLButtonElement>('.nav-burger');
  const navMenu = document.getElementById('nav-menu');

  if (burger && navMenu) {
    const closeMenu = () => {
      if (navMenu.hidden) return;
      navMenu.hidden = true;
      burger.setAttribute('aria-expanded', 'false');
      burger.setAttribute('aria-label', 'Open menu');
    };
    const openMenu = () => {
      navMenu.hidden = false;
      burger.setAttribute('aria-expanded', 'true');
      burger.setAttribute('aria-label', 'Close menu');
    };

    burger.addEventListener('click', (e) => {
      e.stopPropagation();
      navMenu.hidden ? openMenu() : closeMenu();
    });
    navMenu.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));
    document.addEventListener('click', (e) => {
      if (!navMenu.hidden && !navMenu.contains(e.target as Node) && !burger.contains(e.target as Node)) closeMenu();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !navMenu.hidden) { closeMenu(); burger.focus(); }
    });
    window.matchMedia('(max-width: 760px)').addEventListener('change', (e) => {
      if (!e.matches) closeMenu();
    });
  }
</script>
