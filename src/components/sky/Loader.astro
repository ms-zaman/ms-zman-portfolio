---
/**
 * Loader — a load-aware brand entrance (replaces the old "Daybreak" sunrise).
 * A full-screen sky panel with the MZ mark, the wordmark and an indeterminate
 * progress bar. It HOLDS until the fonts and the WebGL hero are actually ready,
 * then fades out in one smooth reveal — no fixed-timer wipe, no cut-off animation,
 * no disjointed poster→WebGL pop. Reduced-motion safe; removed from the DOM when done.
 */
---
<div id="loader" aria-hidden="true">
  <div class="ld-in">
    <span class="ld-badge">MZ</span>
    <span class="ld-name">MS Zaman</span>
    <span class="ld-bar"><i></i></span>
  </div>
</div>

<style>
  #loader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: grid;
    place-items: center;
    background: linear-gradient(180deg, var(--sky-2) 0%, var(--sky-3) 58%, var(--sky-4) 100%);
    opacity: 1;
    transition: opacity .7s ease;
  }
  #loader.done { opacity: 0; pointer-events: none; }

  .ld-in {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    animation: ld-rise .6s cubic-bezier(.22, .61, .36, 1) both;
  }
  @keyframes ld-rise {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: none; }
  }

  /* MZ badge — matches the floating nav mark */
  .ld-badge {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: var(--ink);
    color: #fff;
    display: grid;
    place-items: center;
    font-family: var(--display);
    font-weight: 600;
    font-size: 15px;
    letter-spacing: -.3px;
    box-shadow: 0 10px 28px rgba(20, 44, 84, .25);
  }
  .ld-name {
    font-family: var(--display);
    font-weight: 600;
    font-size: 23px;
    letter-spacing: -.01em;
    color: var(--ink);
  }
  .ld-bar {
    position: relative;
    width: 130px;
    height: 3px;
    border-radius: 3px;
    background: rgba(27, 38, 53, .14);
    overflow: hidden;
  }
  .ld-bar i {
    position: absolute;
    top: 0;
    height: 100%;
    width: 42%;
    border-radius: 3px;
    background: var(--accent);
    animation: ld-slide 1.15s ease-in-out infinite;
  }
  @keyframes ld-slide {
    0% { left: -42%; }
    100% { left: 100%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ld-in { animation: none; }
    .ld-bar i { animation: none; left: 0; width: 100%; }
    #loader { transition: opacity .25s ease; }
  }
</style>

<script>
  // Load-aware dismissal: hold until the fonts + the hero are ready, then reveal once.
  const loader = document.getElementById('loader');
  if (loader) {
    const reduce = window.matchMedia?.('(prefers-reduced-motion: reduce)').matches ?? false;
    const start = performance.now();
    const MIN = reduce ? 0 : 550; // a minimum beat so it never flash-blinks
    const MAX = 4500; // hard cap — never trap the visitor behind the loader
    let done = false;

    const reveal = () => {
      if (done) return;
      done = true;
      const wait = Math.max(0, MIN - (performance.now() - start));
      window.setTimeout(() => {
        loader.classList.add('done');
        const gone = () => loader.remove();
        loader.addEventListener('transitionend', gone, { once: true });
        window.setTimeout(gone, 1000); // fallback if transitionend never fires
      }, wait);
    };

    const fontsReady = document.fonts?.ready ?? Promise.resolve();
    const pageLoaded =
      document.readyState === 'complete'
        ? Promise.resolve()
        : new Promise<void>((r) => window.addEventListener('load', () => r(), { once: true }));

    if (reduce) {
      // no WebGL hero to sync with — reveal as soon as the page is ready
      Promise.all([fontsReady, pageLoaded]).then(reveal);
    } else {
      // prefer to reveal in sync with the WebGL hero's first frame…
      if ((window as unknown as { __skyHeroReady?: boolean }).__skyHeroReady) reveal();
      else window.addEventListener('sky:hero-ready', reveal, { once: true });
      // …but never wait on it forever: reveal shortly after fonts + page are ready
      Promise.all([fontsReady, pageLoaded]).then(() => window.setTimeout(reveal, 900));
    }
    window.setTimeout(reveal, MAX);
  }
</script>
