---
/**
 * OpenSource — two real projects (DesignScan design-token CLI + Redline
 * full-stack news→AI→map pipeline), each with a small illustrative mock.
 * Ported from the frozen prototype (redesign/variant-g §Open source, #opensource).
 * These are the "developer identity" anchor — both are genuine repos.
 */
import SectionHead from './SectionHead.astro';

const gh = 'M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0C6.5 2.8 5.4 3.1 5.4 3.1a4.2 4.2 0 0 0-.1 3.2A4.6 4.6 0 0 0 4 9.5c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2V21';
---
<section class="section" id="opensource">
  <div class="sky-wrap">
    <SectionHead
      eyebrow="Open source"
      title="Building in the open"
      sub="Developer tools I'm building and sharing publicly — more on the way."
    />

    <!-- DesignScan -->
    <a class="oss-card reveal" href="https://github.com/ms-zaman/DesignScan" target="_blank" rel="noopener">
      <div>
        <div class="oss-top">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={gh} /></svg>
          <span class="oss-mit">MIT · Open source</span>
        </div>
        <div class="oss-name">DesignScan</div>
        <p class="oss-desc">Point it at a URL, get a <code>DESIGN.md</code> — automatic design-token extraction (colors, type, spacing, radius) from any live site, ready for your coding agent.</p>
        <div class="oss-tags"><span>TypeScript</span><span>Playwright</span><span>CLI</span><span>Design tokens</span><span>AI agents</span></div>
        <div><span class="wi-link">View on GitHub <span class="ar" aria-hidden="true">↗</span></span></div>
      </div>
      <div class="md-mock" aria-hidden="true">
        <div class="md-bar"><i></i><i></i><i></i><span>DESIGN.md</span></div>
        <div class="md-body">
          <div class="md-row"><span class="md-label">Colors</span>
            <span class="sw" style="background:#3f86cf"></span><span class="sw" style="background:#1b2635"></span>
            <span class="sw" style="background:#f6b352"></span><span class="sw" style="background:#a9cff2"></span>
            <span class="sw" style="background:#ffffff"></span>
          </div>
          <div class="md-row"><span class="md-label">Type</span><span class="md-type">Aa Inter Tight<small>Inter · 17px / 1.6</small></span></div>
          <div class="md-row"><span class="md-label">Spacing</span>
            <span class="bar" style="width:12px"></span><span class="bar" style="width:22px"></span>
            <span class="bar" style="width:38px"></span><span class="bar" style="width:60px"></span>
          </div>
          <div class="md-row"><span class="md-label">Radius</span>
            <span class="md-radius"><i style="border-radius:3px"></i><i style="border-radius:8px"></i><i style="border-radius:999px"></i></span>
          </div>
        </div>
      </div>
    </a>

    <!-- Redline -->
    <a class="oss-card reveal" href="https://github.com/ms-zaman/Redline" target="_blank" rel="noopener">
      <div>
        <div class="oss-top">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={gh} /></svg>
          <span class="oss-mit oss-mit--fs">Full-stack · Open source</span>
        </div>
        <div class="oss-name">Redline</div>
        <p class="oss-desc">An end-to-end data pipeline: it crawls news sources, uses AI to classify and geo-tag each incident, stores it in Postgres, and renders everything on a live, filterable map with charts — from scraper to dashboard.</p>
        <div class="oss-tags"><span>Next.js</span><span>React</span><span>Express</span><span>PostgreSQL</span><span>Puppeteer</span><span>Leaflet</span><span>OpenAI · Gemini</span></div>
        <div><span class="wi-link">View on GitHub <span class="ar" aria-hidden="true">↗</span></span></div>
      </div>
      <div class="md-mock" aria-hidden="true">
        <div class="md-bar"><i></i><i></i><i></i><span>live incident map</span></div>
        <div class="md-body">
          <div class="mm-map">
            <span class="mm-pin" style="top:22%;left:30%"></span>
            <span class="mm-pin hot" style="top:40%;left:58%"></span>
            <span class="mm-pin" style="top:58%;left:38%"></span>
            <span class="mm-pin hot" style="top:66%;left:70%"></span>
            <span class="mm-pin" style="top:34%;left:78%"></span>
            <span class="mm-pin" style="top:74%;left:48%"></span>
          </div>
          <div class="md-row">
            <span class="mm-legend"><span><i></i>reported</span><span><i class="hot"></i>verified</span></span>
            <span class="mm-chart"><i style="height:40%"></i><i style="height:62%"></i><i class="hot" style="height:100%"></i><i style="height:54%"></i><i style="height:78%"></i><i style="height:46%"></i></span>
          </div>
        </div>
      </div>
    </a>

    <div class="oss-more reveal">
      <p><b>More tools are in the works</b> — I'm building open-source projects regularly now. Follow along.</p>
      <a href="https://github.com/ms-zaman" target="_blank" rel="noopener">Follow on GitHub ↗</a>
    </div>
  </div>
</section>

<style>
  .oss-card {
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    gap: 38px;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 34px 38px;
    background: var(--paper);
    transition: .25s;
    box-shadow: 0 14px 40px rgba(40, 80, 140, .06);
  }
  .oss-card + .oss-card { margin-top: 26px; }
  .oss-card:hover { transform: translateY(-3px); border-color: #bcd7f2; box-shadow: 0 22px 54px rgba(40, 80, 140, .13); }
  .oss-card:hover .oss-name { color: var(--accent); }
  .oss-top { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
  .oss-top svg { width: 22px; height: 22px; color: var(--ink); }
  .oss-mit { font-size: 11.5px; font-weight: 600; letter-spacing: .05em; color: #1e7a4d; background: #e4f5eb; padding: 3px 10px; border-radius: 999px; }
  .oss-mit--fs { color: #b4531d; background: #fbeadd; }
  .oss-name { font-family: var(--display); font-size: clamp(24px, 3vw, 32px); font-weight: 600; letter-spacing: -.01em; margin-bottom: 10px; transition: color .2s; }
  .oss-desc { font-size: 15.5px; color: var(--ink-2); line-height: 1.6; max-width: 52ch; margin-bottom: 16px; }
  .oss-desc code { font-size: 13.5px; background: #eef4fb; border: 1px solid #dbe8f6; border-radius: 6px; padding: 1px 7px; color: var(--accent); }
  .oss-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px; }
  .oss-tags span { font-size: 12px; color: var(--accent); background: var(--accent-soft); padding: 4px 11px; border-radius: 7px; }

  .wi-link { display: inline-flex; align-items: center; gap: 8px; font-size: 14.5px; font-weight: 500; color: var(--accent); }
  .wi-link .ar { transition: transform .25s; }
  .oss-card:hover .wi-link .ar { transform: translate(3px, -3px); }

  /* DESIGN.md mock */
  .md-mock { background: #fff; border: 1px solid var(--line); border-radius: 14px; overflow: hidden; box-shadow: 0 16px 36px rgba(40, 80, 140, .10); }
  .md-bar { display: flex; align-items: center; gap: 6px; padding: 9px 13px; border-bottom: 1px solid var(--line); background: var(--paper); }
  .md-bar i { width: 9px; height: 9px; border-radius: 50%; background: #e2e9f2; }
  .md-bar span { margin-left: 6px; font-size: 11.5px; color: var(--ink-3); font-weight: 600; letter-spacing: .02em; }
  .md-body { padding: 17px 18px; display: flex; flex-direction: column; gap: 14px; }
  .md-row { display: flex; align-items: center; gap: 9px; }
  .md-label { font-size: 10.5px; letter-spacing: .1em; text-transform: uppercase; color: var(--ink-3); min-width: 66px; font-weight: 600; }
  .sw { width: 22px; height: 22px; border-radius: 6px; border: 1px solid rgba(20, 40, 70, .08); }
  .md-type { font-family: var(--display); font-weight: 600; font-size: 17px; color: var(--ink); }
  .md-type small { font-family: var(--sans); color: var(--ink-3); font-size: 11.5px; margin-left: 7px; }
  .bar { height: 8px; border-radius: 4px; background: #cfe3f8; }
  .md-radius { display: flex; gap: 8px; align-items: center; }
  .md-radius i { display: block; width: 26px; height: 16px; background: var(--accent-soft); border: 1px solid #cfe3f8; }

  /* incident-map mock */
  .mm-map { position: relative; height: 118px; border-radius: 10px; overflow: hidden; background: linear-gradient(160deg, #eaf2fb, #ddeaf6); border: 1px solid var(--line); }
  .mm-map::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 32% 38%, rgba(63, 134, 207, .12), transparent 58%),
      radial-gradient(circle at 68% 66%, rgba(224, 90, 75, .10), transparent 55%);
  }
  .mm-pin { position: absolute; width: 8px; height: 8px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 0 4px rgba(63, 134, 207, .16); }
  .mm-pin.hot { background: #e05a4b; box-shadow: 0 0 0 4px rgba(224, 90, 75, .18); }
  .mm-legend { display: flex; align-items: center; gap: 14px; font-size: 10.5px; color: var(--ink-3); font-weight: 600; }
  .mm-legend span { display: inline-flex; align-items: center; gap: 5px; }
  .mm-legend i { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); }
  .mm-legend i.hot { background: #e05a4b; }
  .mm-chart { display: flex; align-items: flex-end; gap: 5px; height: 28px; margin-left: auto; }
  .mm-chart i { width: 7px; border-radius: 3px 3px 0 0; background: #cfe3f8; }
  .mm-chart i.hot { background: #f0b1a8; }

  .oss-more {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 18px;
    padding: 18px 24px;
    border: 1px dashed #b5d3f0;
    border-radius: 16px;
    background: #f6faff;
  }
  .oss-more p { font-size: 14.5px; color: var(--ink-2); }
  .oss-more p b { color: var(--ink); font-weight: 600; }
  .oss-more a {
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #fff;
    border: 1px solid var(--line);
    padding: 9px 16px;
    border-radius: 999px;
    transition: .2s;
  }
  .oss-more a:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-1px); }

  @media (max-width: 820px) {
    .oss-card { grid-template-columns: 1fr; padding: 26px 22px; gap: 24px; }
  }
</style>
