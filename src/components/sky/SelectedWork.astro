  { href: 'https://templately.com/pack/d-care-gutenberg-dentist-clinic-template', name: 'D-Care', cat: 'Dental clinic · Gutenberg' },
  { href: 'https://templately.com/pack/naturetreat-gutenberg-ecotourism-template', name: 'NatureTreat', cat: 'Ecotourism · Gutenberg' },
];
---
<section class="section" id="work">
  <div class="sky-wrap">
    <SectionHead
      eyebrow="Selected work"
      title="A few things I've shipped"
      sub="Production templates from the Templately library — used by hundreds of thousands of WordPress makers."
    />

    {works.map((w) => (
      <article class="work-row reveal">
        <div class="wr-info">
          <div class="wr-top">
            <span class="wr-num">{w.num}</span>
            <span class="wr-tags">{w.tags.map((t) => <span>{t}</span>)}</span>
          </div>
          <h3 class="wr-name">{w.name}</h3>
          <div class="wr-sub">{w.sub}</div>
          <p class="wr-desc">{w.desc}</p>
          <div class="wr-metrics">
            {w.metrics.map((m) => <div><b>{m.b}</b> <span>{m.s}</span></div>)}
          </div>
          <a class="wr-link" href={w.href} target="_blank" rel="noopener">
            <span class="wr-live" aria-hidden="true">●</span>
            View on Templately <span class="ar" aria-hidden="true">↗</span>
          </a>
        </div>

        <div
          class="wr-rail"
          tabindex="0"
          role="group"
          aria-label={`${w.name} page previews — scroll horizontally`}
        >
          {w.rail.map((s, i) => (
            <figure class="wr-shot">
              <img
                src={s.src}
                alt={`${w.name} ${s.label.toLowerCase()} page design`}
                width="900"
                height="1030"
                loading="lazy"
                decoding="async"
                fetchpriority={i === 0 ? 'auto' : 'low'}
              />
              <figcaption>{s.label}</figcaption>
            </figure>
          ))}
        </div>
      </article>
    ))}

    <div class="more-tpl reveal">
      <div class="mt-head">
        <div class="mt-title">More from the library</div>
        <div class="mt-note">8 more of 45+ — all live on templately.com</div>
      </div>
      <div class="mt-grid">
        {moreLibrary.map((m) => (
          <a class="mt-row" href={m.href} target="_blank" rel="noopener">
            <span class="mt-name">{m.name}</span>
            <span class="mt-cat">{m.cat}</span>
            <span class="mt-ar" aria-hidden="true">↗</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* distance from the wrap's content edge out to the viewport edge, so the
     rail can bleed off-screen; .sky has overflow-x:hidden so it can't add
     a horizontal scrollbar even when the scrollbar makes 100vw overshoot */
  .work-row {
    --bleed: calc(max(0px, (100vw - var(--wrap)) / 2) + 40px);
    display: grid;
    grid-template-columns: minmax(260px, 340px) 1fr;
    gap: 44px;
    padding: 48px 0;
    border-top: 1px solid var(--line);
  }

  /* — left: sticky info column — */
  .wr-info {
    position: sticky;
    top: 96px;
    align-self: start;
  }
  .wr-top { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
  .wr-num { font-family: var(--display); font-size: 13px; color: var(--ink-3); letter-spacing: .08em; }
  .wr-tags { display: flex; flex-wrap: wrap; gap: 8px; }
  .wr-tags span {
    font-size: 12px;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 4px 11px;
    border-radius: var(--r-sm);
  }
  .wr-name {
    font-family: var(--display);
    font-weight: 600;
    font-size: clamp(28px, 3.4vw, 40px);
    letter-spacing: -.025em;
    line-height: 1.05;
    margin: 0 0 6px;
  }
  .wr-sub { font-size: 15px; color: var(--ink-3); margin-bottom: 16px; }
  .wr-desc {
    font-size: 15.5px;
    color: var(--ink-2);
    line-height: 1.6;
    margin: 0 0 20px;
    max-width: 46ch;
  }
  .wr-metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 22px;
    padding: 13px 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    margin-bottom: 20px;
  }
  .wr-metrics b { font-family: var(--display); font-size: 17px; color: var(--ink); }
  .wr-metrics span { font-size: 12.5px; color: var(--ink-3); }
  .wr-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 14.5px;
    font-weight: 500;
    color: var(--accent);
  }
  .wr-live { color: #1e7a4d; font-size: 10px; }
  .wr-link .ar { transition: transform .25s; }
  .wr-link:hover .ar { transform: translate(3px, -3px); }

  /* — right: horizontal rail of page previews — */
  .wr-rail {
    display: flex;
    gap: 18px;
    overflow-x: auto;
    overscroll-behavior-x: contain;
    scroll-snap-type: x proximity;
    /* bleed past the wrap so the rail runs off the right edge of the screen */
    margin-right: calc(-1 * var(--bleed));
    padding: 4px var(--bleed) 18px 0;
    /* keep the native scrollbar out of the way but still usable */
    scrollbar-width: thin;
    scrollbar-color: var(--line) transparent;
  }
  .wr-shot {
    flex: 0 0 auto;
    margin: 0;
    scroll-snap-align: start;
  }
  .wr-shot img {
    width: auto;
    height: clamp(260px, 34vw, 400px);
    aspect-ratio: 900 / 1030;
    object-fit: cover;
    object-position: top center;
    border-radius: var(--r-md);
    border: 1px solid var(--line);
    background: var(--paper);
    box-shadow: var(--shadow-sm);
    transition: transform .4s ease, box-shadow .4s ease;
  }
  .wr-shot:hover img { transform: translateY(-4px); box-shadow: var(--shadow-md); }
  .wr-shot figcaption {
    font-size: 12.5px;
    color: var(--ink-3);
    margin-top: 10px;
  }

  /* — more-from-the-library list — */
  .more-tpl { margin-top: 56px; padding-top: 36px; border-top: 1px solid var(--line); }
  .mt-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 14px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }
  .mt-title { font-family: var(--display); font-size: 22px; font-weight: 600; letter-spacing: -.01em; }
  .mt-note { font-size: 13.5px; color: var(--ink-3); }
  .mt-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0 44px; }
  .mt-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 13px 0;
    border-bottom: 1px solid var(--line);
    transition: padding .2s;
  }
  .mt-row:hover { padding-left: 8px; }
  .mt-name { font-size: 15px; font-weight: 500; color: var(--ink); transition: color .2s; }
  .mt-row:hover .mt-name { color: var(--accent); }
  .mt-cat { font-size: 12.5px; color: var(--ink-3); margin-left: auto; }
  .mt-ar { color: var(--ink-3); font-size: 13px; transition: .2s; }
  .mt-row:hover .mt-ar { color: var(--accent); transform: translate(2px, -2px); }

  @media (max-width: 900px) {
    /* stack: info on top, rail below — no sticky, it fights a short column */
    .work-row { grid-template-columns: 1fr; gap: 24px; padding: 38px 0; }
    .wr-info { position: static; }
    .wr-desc { max-width: none; }
  }
  @media (max-width: 680px) {
    .work-row { --bleed: 22px; }
    .mt-grid { grid-template-columns: 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    .wr-rail { scroll-snap-type: none; }
    .wr-shot img { transition: none; }
    .wr-shot:hover img { transform: none; }
  }
</style>
