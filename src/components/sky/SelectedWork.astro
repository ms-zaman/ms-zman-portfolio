---
/**
 * SelectedWork — three featured Templately templates, each shown as a
 * sticky text column beside a horizontally-scrolling rail of page previews
 * (layout borrowed from northgarden.com/work, restyled with Sky tokens).
 * Followed by a compact "more from the library" list.
 *
 * Previews are the real per-page thumbnails from the live Templately packs
 * (remote CDN, all 900x1030) — scraped from each pack page, not local assets.
 * `pages`/`sections` counts are the actual item counts in each pack.
 * The rail is a keyboard-scrollable group rather than a list of links, so the
 * row keeps exactly one destination (the pack page) and no nested anchors.
 */
import SectionHead from './SectionHead.astro';

interface Shot {
  label: string;
  src: string;
}

interface Work {
  href: string;
  num: string;
  tags: string[];
  name: string;
  sub: string;
  desc: string;
  metrics: { b: string; s: string }[];
  rail: Shot[];
}

