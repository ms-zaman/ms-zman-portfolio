---
/**
 * SelectedWork — three featured Templately templates (alternating media/text)
 * plus a compact "more from the library" list.
 * Ported from the frozen prototype (redesign/variant-g §Selected work, #work).
 *
 * Thumbnails are the real live Templately OG images (remote CDN URLs) — not
 * local assets. The whole card is a link out to templately.com.
 * The `.work-head` (SectionHead) is the first child of the wrap, so the
 * `:nth-child(even) .wi-media { order: 2 }` alternation matches the prototype.
 */
import SectionHead from './SectionHead.astro';

interface Work {
  href: string;
  img: string;
  alt: string;
  num: string;
  tags: string[];
  name: string;
  desc: string;
  metrics: { b: string; s: string }[];
}

const works: Work[] = [
  {
    href: 'https://templately.com/pack/saastrive-elementor-saas-template',
    img: 'https://items.templately.com/pack-45896bdb2abe1521d2c17044e5ce682a/saastrive-saas-website-template-for-elementor-og_image-MRupjxL.jpg',
    alt: 'SaaStrive SaaS template preview',
    num: '01',
    tags: ['Elementor', 'SaaS'],
    name: 'SaaStrive — SaaS website template',
    desc: 'A conversion-focused SaaS marketing template with pricing, feature, and onboarding sections — built pixel-perfect and fully responsive.',
    metrics: [{ b: '18', s: 'sections' }, { b: '100%', s: 'responsive' }, { b: 'A+', s: 'PageSpeed' }],
  },
  {
    href: 'https://templately.com/pack/mindxtend-business-consultancy-template-gutenberg',
    img: 'https://items.templately.com/pack-cb9f5fd126afed18dbf4da31747040d0/mindxtend-business-consultancy-template-gutenberg-og_image-LQplff8.jpg',
    alt: 'MindXtend consultancy template preview',
    num: '02',
    tags: ['Gutenberg', 'Business'],
    name: 'MindXtend — business consultancy',
    desc: 'A polished consultancy template built natively in the block editor — clean layouts, accessible structure, and easy content editing for clients.',
    metrics: [{ b: '12', s: 'sections' }, { b: 'Native', s: 'Gutenberg' }, { b: 'A+', s: 'PageSpeed' }],
  },
  {
    href: 'https://templately.com/pack/bookanair-elementor-flight-booking-website',
    img: 'https://items.templately.com/pack-fa9c6d144378abf3094ef5fe5e9d2486/bookanair-flight-booking-website-template-for-elementor-og_image-dnKp9fr.jpg',
    alt: 'BookAnAir flight booking template preview',
    num: '03',
    tags: ['Elementor', 'Booking'],
    name: 'BookAnAir — flight booking website',
    desc: "A travel booking template with search-forward layouts and trust-building sections — one of 45+ templates I've shipped for Templately.",
    metrics: [{ b: '16', s: 'sections' }, { b: 'Search', s: '-forward' }, { b: 'A+', s: 'PageSpeed' }],
  },
];

const moreLibrary = [
  { href: 'https://templately.com/pack/naturexplo-gutenberg-travel-eco-tourism-template', name: 'NaturExplo', cat: 'Travel · Gutenberg' },
  { href: 'https://templately.com/pack/flexidropper-elementor-dropshipping-agency-template', name: 'FlexiDropper', cat: 'Dropshipping · Elementor' },
  { href: 'https://templately.com/pack/snapcatch-gutenberg-photography-template', name: 'SnapCatch', cat: 'Photography · Gutenberg' },
  { href: 'https://templately.com/pack/multigency-elementor-multipurpose-template', name: 'Multigency', cat: 'Multipurpose · Elementor' },
  { href: 'https://templately.com/pack/noocodehub-gutenberg-no-code-community', name: 'NooCodeHub', cat: 'Community · Gutenberg' },
  { href: 'https://templately.com/pack/hiringfinds-elementor-job-board-template', name: 'HiringFinds', cat: 'Job board · Elementor' },
  { href: 'https://templately.com/pack/d-care-gutenberg-dentist-clinic-template', name: 'D-Care', cat: 'Dental clinic · Gutenberg' },
  { href: 'https://templately.com/pack/naturetreat-gutenberg-ecotourism-template', name: 'NatureTreat', cat: 'Ecotourism · Gutenberg' },
];
---
<section class="section" id="work">
  <div class="sky-wrap">
    <SectionHead
      eyebrow="Selected work"
      title="A few things I've shipped"
      sub="Production templates from the Templately library — used by hundreds of thousands of WordPress makers."
    />

    {works.map((w) => (
      <a class="work-item reveal" href={w.href} target="_blank" rel="noopener">
        <div class="wi-media">
          <span class="wi-live">● Live</span>
          <img src={w.img} alt={w.alt} loading="lazy" />
        </div>
        <div>
          <div class="wi-num">{w.num}</div>
          <div class="wi-tags">{w.tags.map((t) => <span>{t}</span>)}</div>
          <div class="wi-name">{w.name}</div>
          <p class="wi-desc">{w.desc}</p>
          <div class="wi-metrics">
            {w.metrics.map((m) => <div><b>{m.b}</b> <span>{m.s}</span></div>)}
          </div>
          <div><span class="wi-link">View on Templately <span class="ar" aria-hidden="true">↗</span></span></div>
        </div>
      </a>
    ))}

    <div class="more-tpl reveal">
      <div class="mt-head">
        <div class="mt-title">More from the library</div>
        <div class="mt-note">8 more of 45+ — all live on templately.com</div>
      </div>
      <div class="mt-grid">
        {moreLibrary.map((m) => (
          <a class="mt-row" href={m.href} target="_blank" rel="noopener">
            <span class="mt-name">{m.name}</span>
            <span class="mt-cat">{m.cat}</span>
            <span class="mt-ar" aria-hidden="true">↗</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .work-item {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 36px;
    align-items: center;
    padding: 34px 0;
    border-top: 1px solid var(--line);
  }
  .wi-media {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--paper);
    aspect-ratio: 16 / 10;
    box-shadow: 0 20px 50px rgba(40, 80, 140, .10);
  }
  .wi-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform .5s ease;
  }
  .work-item:hover .wi-media img { transform: scale(1.04); }
  .wi-live {
    position: absolute;
    top: 12px;
    left: 12px;
    font-size: 11px;
    font-weight: 600;
    color: #1e7a4d;
    background: #e4f5eb;
    padding: 4px 10px;
    border-radius: 999px;
    z-index: 2;
  }

  .wi-num { font-family: var(--display); font-size: 18px; color: var(--ink-3); margin-bottom: 12px; }
  .wi-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }
  .wi-tags span {
    font-size: 12px;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 4px 11px;
    border-radius: 7px;
  }
  .wi-name {
    font-family: var(--display);
    font-weight: 600;
    font-size: clamp(22px, 2.6vw, 30px);
    letter-spacing: -.01em;
    line-height: 1.12;
    margin-bottom: 12px;
  }
  .wi-desc {
    font-size: 15.5px;
    color: var(--ink-2);
    line-height: 1.6;
    margin-bottom: 16px;
    max-width: 52ch;
  }
  .wi-metrics {
    display: flex;
    gap: 22px;
    padding: 12px 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    margin: 0 0 16px;
  }
  .wi-metrics b { font-family: var(--display); font-size: 18px; color: var(--ink); }
  .wi-metrics span { font-size: 12.5px; color: var(--ink-3); }
  .wi-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 14.5px;
    font-weight: 500;
    color: var(--accent);
  }
  .wi-link .ar { transition: transform .25s; }
  .work-item:hover .wi-link .ar { transform: translate(3px, -3px); }

  /* alternate media to the right on every other card (prototype parity) */
  .work-item:nth-child(even) .wi-media { order: 2; }

  /* more-from-the-library list */
  .more-tpl { margin-top: 56px; padding-top: 36px; border-top: 1px solid var(--line); }
  .mt-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 14px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }
  .mt-title { font-family: var(--display); font-size: 22px; font-weight: 600; letter-spacing: -.01em; }
  .mt-note { font-size: 13.5px; color: var(--ink-3); }
  .mt-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0 44px; }
  .mt-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 13px 0;
    border-bottom: 1px solid var(--line);
    transition: padding .2s;
  }
  .mt-row:hover { padding-left: 8px; }
  .mt-name { font-size: 15px; font-weight: 500; color: var(--ink); transition: color .2s; }
  .mt-row:hover .mt-name { color: var(--accent); }
  .mt-cat { font-size: 12.5px; color: var(--ink-3); margin-left: auto; }
  .mt-ar { color: var(--ink-3); font-size: 13px; transition: .2s; }
  .mt-row:hover .mt-ar { color: var(--accent); transform: translate(2px, -2px); }

  @media (max-width: 780px) {
    .work-item,
    .work-item:nth-child(even) .wi-media { grid-template-columns: 1fr; order: 0; }
    .work-item { gap: 18px; }
  }
  @media (max-width: 680px) {
    .mt-grid { grid-template-columns: 1fr; }
  }
</style>
