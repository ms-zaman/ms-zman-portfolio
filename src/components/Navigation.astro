---
/**
 * Navigation — the dark-theme nav for the blog and 404 (BaseLayout).
 * The homepage has its own Sky nav, so every section link here is
 * cross-page (`/#work`) rather than a same-page anchor.
 */
import ThemeToggle from './ThemeToggle.jsx';
import MobileMenu from './MobileMenu.jsx';
---

<nav class="nav" role="navigation" aria-label="Main navigation">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="MS Zaman — Home">
      <span>MS</span>.Zaman
    </a>

    <!-- Desktop Navigation -->
    <ul class="nav-links">
      <li><a href="/#work">Work</a></li>
      <li><a href="/#experience">Experience</a></li>
      <li><a href="/#contact">Contact</a></li>
      <li><a href="/blog">Blog</a></li>
      <li style="display: flex; align-items: center;">
        <ThemeToggle client:load />
      </li>
      <li>
        <span class="status-badge">
          <span class="status-dot" aria-hidden="true"></span>
          Available
        </span>
      </li>
    </ul>

    <!-- Mobile menu — React island for toggle interactivity -->
    <MobileMenu client:load />
  </div>
</nav>
