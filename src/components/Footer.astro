  </div>
  <a href="#main-content" class="back-to-top">
    Back to top
    <svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display: inline-block; vertical-align: -0.125em;">
      <path d="M12 5v14" />
